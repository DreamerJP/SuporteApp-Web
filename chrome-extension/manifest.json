{
  "manifest_version": 3,
  "name": "SuporteApp",
  "version": "1.0.0",
  "description": "Textos rápidos para suporte técnico e abertura automática de IPs.",
  "permissions": ["storage", "clipboardRead", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SuporteApp",
    "default_icon": {
      "192": "icons/icon-192.png",
      "512": "icons/icon-512.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "192": "icons/icon-192.png",
    "512": "icons/icon-512.png"
  }
}
